    <!-- Tracker settings screen -->
    <string name="tracker_settings_header">My Car Tracker — ارسال موقعیت مکانی از طریق پیامک</string>
    <string name="tracker_settings_intro1">با پیامک \'sendloc\' از یکی از شماره‌های مجاز زیر، موقعیت فوری ارسال می‌شود.</string>
    <string name="tracker_settings_intro2">با \'autosend 30 on\' یا \'autosend off\' ارسال خودکار پیامکی از راه دور کنترل می‌شود. با \'sendlog\' فایل‌های لاگ (فشرده zip) به ایمیل ارسال می‌شوند (نیاز به اینترنت)، با \'dellog\' آرشیوهای قدیمی حذف می‌شوند، و با \'ping\' وضعیت زنده‌بودن و باتری ردیاب پرسیده می‌شود.</string>
    <string name="tracker_settings_admin_numbers_label">شماره‌های مجاز برای این دستورات (با کاما جدا کنید):</string>
    <string name="tracker_settings_numbers_hint">مثلا 09121234567, 09123334455</string>
    <string name="tracker_settings_autosend_numbers_label">شماره(های) ارسال خودکار موقعیت و هشدار حرکت (با کاما جدا کنید):</string>
    <string name="tracker_settings_autosend_interval_label">بازه ارسال خودکار پیامکی (دقیقه، حداقل 15):</string>
    <string name="tracker_settings_interval_hint">مثلا 60</string>
    <string name="tracker_settings_autosend_enable_switch">فعال‌سازی ارسال خودکار پیامکی</string>
    <string name="tracker_settings_log_save_header">ذخیره‌ی دوره‌ای مختصات در فایل (مستقل از ارسال خودکار پیامکی)</string>
    <string name="tracker_settings_log_save_note">این کار همیشه با تایمر خودش انجام می‌شود، چه ارسال خودکار پیامکی روشن باشد چه خاموش.</string>
    <string name="tracker_settings_log_interval_label">بازه ذخیره در فایل (دقیقه، حداقل 15):</string>
    <string name="tracker_settings_min_distance_label">حداقل فاصله جابجایی برای ثبت در فایل (متر، 0 = غیرفعال یعنی همیشه ثبت شود):</string>
    <string name="tracker_settings_min_distance_hint">مثلا 200</string>
    <string name="tracker_settings_movement_alert_switch">ارسال پیامک به شماره(های) بالا وقتی این میزان جابجایی رخ دهد</string>
    <string name="tracker_settings_battery_alert_header">هشدار باتری کم</string>
    <string name="tracker_settings_battery_alert_note">اگر فعال باشد، با رسیدن باتری گوشیِ ردیاب به آستانه‌ی زیر (یا بازگشت به بالای آن)، یک پیامک هشدار به شماره‌های مجاز فرستاده می‌شود.</string>
    <string name="tracker_settings_battery_alert_switch">فعال‌سازی هشدار باتری کم</string>
    <string name="tracker_settings_battery_threshold_label">آستانه‌ی هشدار (درصد باتری):</string>
    <string name="tracker_settings_battery_hint">مثلا 15</string>
    <string name="tracker_settings_geofence_header">حصار جغرافیایی (Geofence)</string>
    <string name="tracker_settings_geofence_note">اگر فعال باشد، وقتی خودرو از محدوده‌ی دایره‌ای زیر خارج یا به آن بازگردد، یک پیامک هشدار به شماره‌های مجاز فرستاده می‌شود.</string>
    <string name="tracker_settings_geofence_switch">فعال‌سازی حصار جغرافیایی</string>
    <string name="tracker_settings_geofence_radius_label">شعاع محدوده (متر):</string>
    <string name="tracker_settings_geofence_radius_hint">مثلا 500</string>
    <string name="tracker_settings_set_geofence_center_button">ثبت موقعیت فعلی به‌عنوان مرکز محدوده</string>
    <string name="tracker_settings_email_header">تنظیمات ارسال فایل لاگ به ایمیل (برای دستور sendlog)</string>
    <string name="tracker_settings_email_note">برای ارسال ایمیل، اپ باید با یک حساب ایمیل واسط وارد شود. توصیه می‌شود یک حساب Gmail مخصوص همین کار بسازید و از آن یک «App Password» بگیرید (نه رمز عبور اصلی جیمیل).</string>
    <string name="tracker_settings_recipient_email_label">ایمیل گیرنده (جایی که لاگ باید ارسال شود):</string>
    <string name="tracker_settings_recipient_email_hint">مثلا you@example.com</string>
    <string name="tracker_settings_sender_email_label">ایمیل فرستنده (حساب واسط برای ارسال):</string>
    <string name="tracker_settings_sender_email_hint">مثلا mycartracker@gmail.com</string>
    <string name="tracker_settings_app_password_label">App Password ایمیل فرستنده:</string>
    <string name="tracker_settings_app_password_hint">App Password ۱۶ کاراکتری Gmail</string>
    <string name="tracker_settings_smtp_host_label">آدرس سرور SMTP:</string>
    <string name="tracker_settings_smtp_port_label">پورت SMTP:</string>
    <string name="tracker_settings_pin_header">کد امنیتی دستورها (اختیاری)</string>
    <string name="tracker_settings_pin_note">اگر این کد را تنظیم کنید، هر دستور پیامکی باید با همین کد شروع شود (مثلاً «1234 sendloc»)؛ در غیر این صورت نادیده گرفته می‌شود. همین کد باید در صفحه‌ی «تنظیمات Tracker» روی گوشیِ نمایشگر هم وارد شود.</string>
    <string name="tracker_settings_pin_hint">خالی = بدون کد امنیتی</string>
    <string name="tracker_settings_background_header">پایداری اجرا در پس‌زمینه</string>
    <string name="tracker_settings_background_note">بعضی گوشی‌ها اپ‌های پس‌زمینه را برای صرفه‌جویی باتری می‌بندند و ردیابی را مختل می‌کنند. با زدن دکمه‌ی زیر، از اندروید بخواهید این اپ را از بهینه‌سازی باتری معاف کند.</string>
    <string name="tracker_settings_battery_optimization_button">معافیت از بهینه‌سازی باتری</string>
    <string name="tracker_settings_save_button">ذخیره و درخواست مجوزها</string>
    <string name="tracker_settings_permissions_denied">برخی مجوزها داده نشد. بدون آن‌ها برنامه به‌درستی کار نخواهد کرد.</string>
    <string name="tracker_settings_battery_optimization_unsupported_os">این قابلیت فقط از اندروید ۶ (Marshmallow) به بعد در دسترس است؛ نسخه‌ی اندروید این گوشی قدیمی‌تر است.</string>
    <string name="tracker_settings_battery_optimization_unavailable">این قابلیت روی این گوشی در دسترس نیست</string>
    <string name="tracker_settings_battery_optimization_already_exempt">این برنامه از قبل از بهینه‌سازی باتری معاف است</string>
    <string name="tracker_settings_battery_optimization_failed">این گوشی از تنظیم معافیت باتری پشتیبانی نمی‌کند یا این صفحه رویش در دسترس نیست.</string>
    <string name="tracker_settings_geofence_center_current">مرکز فعلی: %1$s, %2$s</string>
    <string name="tracker_settings_geofence_center_not_set">مرکزی تنظیم نشده — روی دکمه‌ی بالا بزنید تا موقعیت فعلی به‌عنوان مرکز ثبت شود</string>
    <string name="tracker_settings_geofence_location_permission_needed">ابتدا مجوز موقعیت مکانی را بدهید و دوباره تلاش کنید</string>
    <string name="tracker_settings_geofence_getting_location">در حال دریافت موقعیت فعلی...</string>
    <string name="tracker_settings_geofence_location_failed">دریافت موقعیت فعلی ممکن نشد</string>
    <string name="tracker_settings_geofence_center_saved">مرکز حصار جغرافیایی ثبت شد</string>
    <string name="tracker_settings_error_autosend_needs_number">برای ارسال خودکار، حداقل یک شماره تلفن وارد کنید</string>
    <string name="tracker_settings_error_movealert_needs_number">برای هشدار حرکت، حداقل یک شماره تلفن وارد کنید</string>
    <string name="tracker_settings_error_geofence_needs_center">برای حصار جغرافیایی، ابتدا مرکز را با دکمه‌ی بالا ثبت کنید</string>
    <string name="tracker_settings_error_min_interval">حداقل بازه مجاز ۱۵ دقیقه است</string>
    <string name="tracker_settings_warning_no_admin_numbers">توجه: چون هیچ شماره مجازی ثبت نکردید، دستورات پیامکی (sendloc, autosend, sendlog, dellog, ping) و هشدارهای SIM/Geofence ارسال نمی‌شوند</string>
    <string name="tracker_settings_saved_autosend_on">تنظیمات ذخیره شد. ارسال خودکار پیامکی هر %1$d دقیقه فعال است. ذخیره در فایل هر %2$d دقیقه ادامه دارد.</string>
