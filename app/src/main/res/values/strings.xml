    <!-- Tracker settings screen -->
    <string name="tracker_settings_header">My Car Tracker — Send location via SMS</string>
    <string name="tracker_settings_intro1">Sending \'sendloc\' from one of the allowed numbers below requests the current location instantly.</string>
    <string name="tracker_settings_intro2">\'autosend 30 on\' or \'autosend off\' controls automatic SMS location sending remotely. \'sendlog\' emails the (zipped) log files (requires internet), \'dellog\' deletes old archives, and \'ping\' asks whether the tracker is alive and its battery level.</string>
    <string name="tracker_settings_admin_numbers_label">Numbers allowed to send these commands (comma-separated):</string>
    <string name="tracker_settings_numbers_hint">e.g. 09121234567, 09123334455</string>
    <string name="tracker_settings_autosend_numbers_label">Number(s) for automatic location &amp; movement alerts (comma-separated):</string>
    <string name="tracker_settings_autosend_interval_label">Automatic SMS send interval (minutes, minimum 15):</string>
    <string name="tracker_settings_interval_hint">e.g. 60</string>
    <string name="tracker_settings_autosend_enable_switch">Enable automatic SMS sending</string>
    <string name="tracker_settings_log_save_header">Periodically save coordinates to a file (independent of automatic SMS sending)</string>
    <string name="tracker_settings_log_save_note">This always runs on its own timer, whether automatic SMS sending is on or off.</string>
    <string name="tracker_settings_log_interval_label">File save interval (minutes, minimum 15):</string>
    <string name="tracker_settings_min_distance_label">Minimum movement distance to log (meters; 0 = disabled, always log):</string>
    <string name="tracker_settings_min_distance_hint">e.g. 200</string>
    <string name="tracker_settings_movement_alert_switch">Send SMS to the number(s) above when this much movement occurs</string>
    <string name="tracker_settings_battery_alert_header">Low Battery Alert</string>
    <string name="tracker_settings_battery_alert_note">If enabled, an alert SMS is sent to the allowed numbers when the tracker phone\'s battery reaches the threshold below (or rises back above it).</string>
    <string name="tracker_settings_battery_alert_switch">Enable low battery alert</string>
    <string name="tracker_settings_battery_threshold_label">Alert threshold (battery %):</string>
    <string name="tracker_settings_battery_hint">e.g. 15</string>
    <string name="tracker_settings_geofence_header">Geofence</string>
    <string name="tracker_settings_geofence_note">If enabled, an alert SMS is sent to the allowed numbers whenever the car leaves or re-enters the circular area below.</string>
    <string name="tracker_settings_geofence_switch">Enable geofence</string>
    <string name="tracker_settings_geofence_radius_label">Area radius (meters):</string>
    <string name="tracker_settings_geofence_radius_hint">e.g. 500</string>
    <string name="tracker_settings_set_geofence_center_button">Set current location as the area\'s center</string>
    <string name="tracker_settings_email_header">Email log settings (for the sendlog command)</string>
    <string name="tracker_settings_email_note">To send email, the app needs to sign in with an intermediary email account. We recommend creating a dedicated Gmail account for this and generating an "App Password" for it (not your main Gmail password).</string>
    <string name="tracker_settings_recipient_email_label">Recipient email (where the log should be sent):</string>
    <string name="tracker_settings_recipient_email_hint">e.g. you@example.com</string>
    <string name="tracker_settings_sender_email_label">Sender email (the intermediary account used to send):</string>
    <string name="tracker_settings_sender_email_hint">e.g. mycartracker@gmail.com</string>
    <string name="tracker_settings_app_password_label">Sender email App Password:</string>
    <string name="tracker_settings_app_password_hint">16-character Gmail App Password</string>
    <string name="tracker_settings_smtp_host_label">SMTP server address:</string>
    <string name="tracker_settings_smtp_port_label">SMTP port:</string>
    <string name="tracker_settings_pin_header">Command Security Code (optional)</string>
    <string name="tracker_settings_pin_note">If you set this code, every SMS command must start with it (e.g. "1234 sendloc"); otherwise it\'s ignored. The same code must also be entered on the "Tracker Settings" screen on the Viewer phone.</string>
    <string name="tracker_settings_pin_hint">Empty = no security code</string>
    <string name="tracker_settings_background_header">Background Reliability</string>
    <string name="tracker_settings_background_note">Some phones kill background apps to save battery, which can disrupt tracking. Tap the button below to ask Android to exempt this app from battery optimization.</string>
    <string name="tracker_settings_battery_optimization_button">Exempt from battery optimization</string>
    <string name="tracker_settings_save_button">Save and request permissions</string>
    <string name="tracker_settings_permissions_denied">Some permissions were not granted. The app won\'t work correctly without them.</string>
    <string name="tracker_settings_battery_optimization_unsupported_os">This feature is only available on Android 6 (Marshmallow) or later; this phone\'s Android version is older.</string>
    <string name="tracker_settings_battery_optimization_unavailable">This feature isn\'t available on this phone</string>
    <string name="tracker_settings_battery_optimization_already_exempt">This app is already exempt from battery optimization</string>
    <string name="tracker_settings_battery_optimization_failed">This phone doesn\'t support the battery-optimization exemption setting, or this screen isn\'t available on it.</string>
    <string name="tracker_settings_geofence_center_current">Current center: %1$s, %2$s</string>
    <string name="tracker_settings_geofence_center_not_set">No center set — tap the button above to record the current location as the center</string>
