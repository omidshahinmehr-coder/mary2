<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/viewer_tracker_settings_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/viewer_tracker_settings_subtitle"
            android:textSize="12sp"
            android:textColor="@color/color_text_hint"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/viewer_tracker_phone_label" />

        <EditText
            android:id="@+id/trackerPhoneInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:hint="@string/viewer_tracker_phone_hint" />

        <Button
            android:id="@+id/saveTrackerPhoneButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_save_phone_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="@string/viewer_pin_label" />

        <EditText
            android:id="@+id/commandPinInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/viewer_pin_hint" />

        <Button
            android:id="@+id/saveCommandPinButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_save_pin_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- Autosend -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_autosend_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/viewer_autosend_interval_label" />

        <EditText
            android:id="@+id/autosendIntervalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="15" />

        <Button
            android:id="@+id/autosendOnButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_autosend_on_button" />

        <Button
            android:id="@+id/autosendOffButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_autosend_off_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- MoveAlert -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_movealert_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/viewer_movealert_distance_label" />

        <EditText
            android:id="@+id/moveAlertDistanceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="50" />

        <Button
            android:id="@+id/moveAlertOnButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_movealert_on_button" />

        <Button
            android:id="@+id/moveAlertOffButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_movealert_off_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- Geofence -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_geofence_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="@string/viewer_geofence_note"
            android:textSize="12sp"
            android:textColor="@color/color_text_hint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/viewer_geofence_radius_label" />

        <EditText
            android:id="@+id/geofenceRadiusInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="500" />

        <Button
            android:id="@+id/geofenceOnButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_geofence_on_button" />

        <Button
            android:id="@+id/geofenceOffButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_geofence_off_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- LowBatteryAlert -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_lowbattery_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/viewer_lowbattery_threshold_label" />

        <EditText
            android:id="@+id/lowBatteryPercentInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="15" />

        <Button
            android:id="@+id/lowBatteryOnButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_lowbattery_on_button" />

        <Button
            android:id="@+id/lowBatteryOffButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_lowbattery_off_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- SetAdminNumbers -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_set_admin_numbers_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="@string/viewer_set_admin_numbers_note"
            android:textSize="12sp"
            android:textColor="@color/color_text_hint" />

        <EditText
            android:id="@+id/adminNumbersInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:hint="@string/viewer_numbers_hint" />

        <Button
            android:id="@+id/setAdminNumbersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_set_admin_numbers_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- SetAutosendNumbers -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_set_autosend_numbers_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="@string/viewer_set_autosend_numbers_note"
            android:textSize="12sp"
            android:textColor="@color/color_text_hint" />

        <EditText
            android:id="@+id/autosendNumbersInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:hint="@string/viewer_numbers_hint" />

        <Button
            android:id="@+id/setAutosendNumbersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/viewer_set_autosend_numbers_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <!-- SetLogTimer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/viewer_set_log_timer_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/viewer_log_timer_label" />

        <EditText
            android:id="@+id/logTimerInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="15" />

        <Button
            android:id="@+id/setLogTimerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="@string/viewer_set_log_timer_button" />

    </LinearLayout>
</ScrollView>
